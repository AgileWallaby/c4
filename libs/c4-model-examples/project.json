{
  "name": "c4-model-examples",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/c4-model-examples/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/c4-model-examples",
        "main": "libs/c4-model-examples/src/index.ts",
        "tsConfig": "libs/c4-model-examples/tsconfig.lib.json",
        "assets": ["libs/c4-model-examples/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "configFile": "libs/c4-model-examples/vitest.config.ts"
      },
      "configurations": {
        "ci": {
          "coverage": true
        }
      }
    },
    "generate-diagrams": {
      "executor": "nx:run-commands",
      "dependsOn": [{ "projects": ["c4-model"], "target": "build" }],
      "options": {
        "command": "node --import tsx/esm libs/c4-model-examples/src/generate.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
