{
  "name": "c4-model",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/c4-model/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "_esbuild": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/c4-model",
        "main": "libs/c4-model/src/index.ts",
        "tsConfig": "libs/c4-model/tsconfig.lib.json",
        "format": ["esm", "cjs"],
        "bundle": true,
        "declaration": true,
        "outputFileName": "src/index.js",
        "excludeFromExternal": ["change-case"],
        "assets": ["libs/c4-model/README.md"]
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/c4-model"],
      "dependsOn": ["_esbuild"],
      "options": {
        "command": "pnpm exec dts-bundle-generator --out-file dist/libs/c4-model/src/index.d.ts --no-check libs/c4-model/src/index.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/c4-model/**/*.ts",
          "libs/c4-model/package.json"
        ]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "configFile": "libs/c4-model/vitest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "coverage": true
        }
      }
    }
  }
}
