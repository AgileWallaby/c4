exports[`can write to dsl > full model with all view types 1`] = `
"workspace "name" {
  model {
    // Elements
    person1 = person "person1" {
      tags "Element" "Person"
    }
    person2 = person "person2" {
      tags "Element" "Person"
    }
    softwareSystem1 = softwareSystem "softwareSystem1" {
      description "description"
      tags "tag1" "tag2" "Element" "Software System"
      container1 = container "container1" {
        description "description"
        tags "tag1" "tag2" "Element" "Container"
        technology "technology"
        component1 = component "component1" {
          description "description"
          tags "tag1" "tag2" "Element" "Component"
          technology "technology"
        }
      }
      container2 = container "container2" {
        description "description"
        tags "tag1" "tag2" "Element" "Container"
        technology "technology"
        component2 = component "component2" {
          description "description"
          tags "tag1" "tag2" "Element" "Component"
          technology "technology"
        }
      }
    }
    softwareSystem2 = softwareSystem "softwareSystem2" {
      tags "Element" "Software System"
      grp2 = group "grp2" {
        container3 = container "container3" {
          tags "Element" "Container"
          component3 = component "component3" {
            tags "Element" "Component"
          }
        }
        container4 = container "container4" {
          tags "Element" "Container"
          component5 = component "component5" {
            tags "Element" "Component"
          }
          anotherGroup = group "anotherGroup" {
            component4 = component "component4" {
              tags "Element" "Component"
            }
          }
        }
      }
    }
    myGroup = group "myGroup" {
      person3 = person "person3" {
        tags "Element" "Person"
      }
      person4 = person "person4" {
        tags "Element" "Person"
      }
    }
    // Relationships
    person1 -> person2 "description" {
      tags "tag1" "tag2" "Relationship"
    }
    person1 -> softwareSystem1 "uses" {
      tags "Relationship"
    }
    person1 -> softwareSystem2 "uses" {
      tags "Relationship"
    }
    person2 -> person1 "description" {
      tags "tag1" "tag2" "Relationship"
    }
    person2 -> softwareSystem1 "uses" {
      tags "Relationship"
    }
    softwareSystem1 -> softwareSystem2 "uses" {
      tags "Relationship"
    }
    softwareSystem2 -> softwareSystem1 "uses" {
      tags "Relationship"
    }
  }
  views {
    // System Landscape Views
    systemLandscape "someName1" {
      description "someDescription"
      include *
    }
    // System Context Views
    systemContext "softwareSystem1" "someName" {
      description "someDescription"
      title "My Title"
      include *
    }
    // Container Views
    container "softwareSystem1" "someName2s" {
      description "someDescription"
      include *
    }
    // Component Views
    component "container1" "someName3" {
      description "someOtherDescripgtion"
      title "The Other Title"
      include *
    }
  }
}
"
`;

exports[`can write to dsl > includeElement accepts Person on container view 1`] = `
"workspace "m" {
  model {
    // Elements
    alice = person "alice" {
      tags "Element" "Person"
    }
    mySystem = softwareSystem "MySystem" {
      tags "Element" "Software System"
    }
    // Relationships
  }
  views {
    // System Landscape Views
    // System Context Views
    // Container Views
    container "mySystem" "cv" {
      description "desc"
      include alice
    }
    // Component Views
  }
}
"
`;

exports[`can write to dsl > per-view properties - emitted inside view block 1`] = `
"workspace "m" {
  model {
    // Elements
    // Relationships
  }
  views {
    // System Landscape Views
    systemLandscape "sl" {
      description "desc"
      properties {
        "structurizr.sort" "created"
        "custom.key" "some value"
      }
    }
    // System Context Views
    // Container Views
    // Component Views
  }
}
"
`;

