exports[`can write to dsl > autoLayout - bare 1`] = `
"workspace "m" {
  model {
    // Elements
    // Relationships
  }
  views {
    // System Landscape Views
    systemLandscape "sl" {
      description "desc"
      autoLayout
    }
    // System Context Views
    // Container Views
    // Component Views
  }
}
"
`;

