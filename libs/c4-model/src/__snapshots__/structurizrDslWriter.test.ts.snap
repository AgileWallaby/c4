exports[`can write to dsl > should output archetypes block when archetypes are used 1`] = `
"workspace "archModel" {
  model {
    archetypes {
      springBootApp = container {
        technology "Spring Boot"
        tags "Application"
      }
      microservice = springBootApp {
        tags "Microservice"
      }
    }
    // Elements
    mySystem = softwareSystem "mySystem" {
      tags "Element" "Software System"
      webApp = springBootApp "Web App" {
      }
      api = microservice "API" {
        description "REST API"
      }
    }
    // Relationships
  }
  views {
    // System Landscape Views
    // System Context Views
    // Container Views
    // Component Views
  }
}
"
`;

exports[`can write to dsl > should output relationship archetypes when used 1`] = `
"workspace "relArchModel" {
  model {
    archetypes {
      sync = -> {
        tags "Synchronous"
      }
      https = --sync-> {
        technology "HTTPS"
      }
    }
    // Elements
    user = person "user" {
      tags "Element" "Person"
    }
    mySystem = softwareSystem "mySystem" {
      tags "Element" "Software System"
    }
    // Relationships
    user --https-> mySystem "Makes API calls" {
    }
  }
  views {
    // System Landscape Views
    // System Context Views
    // Container Views
    // Component Views
  }
}
"
`;

exports[`can write to dsl > should use camelCase identifiers for multi-word group names 1`] = `
